# نسخ إلى .env.production أو .env عند بناء الواجهة للإنتاج
# عنوان الـ API العام (Render) — يجب أن ينتهي بـ /api أو بدون، حسب ما تضعه في auth.js
# مثال: VITE_API_BASE_URL=https://radar-backend.onrender.com/api
# VITE_API_BASE_URL=

# رابط Django Admin (لما بدك زر الأدمن يفتح سيرفرك مباشرة حتى لو الواجهة شغالة محلياً)
# مثال: VITE_DJANGO_ADMIN_URL=https://radar-rbvob.ondigitalocean.app/api/admin/
# VITE_DJANGO_ADMIN_URL=

# واجهة «خدمات مجتمعية فقط»: إخفاء المتاجر/السلال/المفضلة من التنقّل العام (true/false)
# VITE_PUBLIC_COMMUNITY_ONLY_UI=true
